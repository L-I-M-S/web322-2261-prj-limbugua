<div class="min-h-screen bg-green-50 flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-md">

    <div class="card bg-white shadow-lg">
      <div class="card-body p-8">

        <h1 class="text-2xl font-bold text-green-900 text-center mb-6">Log In</h1>

        <% if (errors && errors.length > 0) { %>
          <div class="alert alert-error mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <ul class="list-disc list-inside text-sm">
              <% errors.forEach(function(err) { %>
                <li><%= err %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <form action="/log-in" method="POST" novalidate>

          <div class="form-control mb-3">
            <label class="label" for="email">
              <span class="label-text font-medium">Email</span>
            </label>
            <input type="text" id="email" name="email"
              value="<%= formData.email || '' %>"
              autocomplete="email"
              class="input input-bordered w-full" />
          </div>

          <div class="form-control mb-4">
            <label class="label" for="password">
              <span class="label-text font-medium">Password</span>
            </label>
            <input type="password" id="password" name="password"
              autocomplete="current-password"
              class="input input-bordered w-full" />
          </div>

          <div class="form-control mb-6">
            <label class="label">
              <span class="label-text font-medium">Logging in as</span>
            </label>
            <div class="flex gap-6 mt-1">
              <label class="flex items-center gap-2 cursor-pointer" for="roleCustomer">
                <input type="radio" id="roleCustomer" name="role" value="customer"
                  class="radio radio-success"
                  <%= (!formData.role || formData.role === 'customer') ? 'checked' : '' %> />
                <span class="text-sm">Customer</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer" for="roleClerk">
                <input type="radio" id="roleClerk" name="role" value="clerk"
                  class="radio radio-success"
                  <%= formData.role === 'clerk' ? 'checked' : '' %> />
                <span class="text-sm">Data Clerk</span>
              </label>
            </div>
          </div>

          <button type="submit" class="btn btn-success w-full">Log In</button>
        </form>

        <p class="text-center text-sm text-gray-500 mt-4">
          Don't have an account? <a href="/sign-up" class="link link-success">Sign Up</a>
        </p>

      </div>
    </div>

  </div>
</div>
