<div class="min-h-screen bg-green-50 flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-md">

    <div class="card bg-white shadow-lg">
      <div class="card-body p-8">

        <h1 class="text-2xl font-bold text-green-900 text-center mb-6">Create an Account</h1>

        <% if (errors && errors.length > 0) { %>
          <div class="alert alert-error mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <ul class="list-disc list-inside text-sm">
              <% errors.forEach(function(err) { %>
                <li><%= err %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <form action="/sign-up" method="POST" novalidate>

          <div class="form-control mb-3">
            <label class="label" for="firstName">
              <span class="label-text font-medium">First Name</span>
            </label>
            <input type="text" id="firstName" name="firstName"
              value="<%= formData.firstName || '' %>"
              autocomplete="given-name"
              class="input input-bordered w-full" />
          </div>

          <div class="form-control mb-3">
            <label class="label" for="lastName">
              <span class="label-text font-medium">Last Name</span>
            </label>
            <input type="text" id="lastName" name="lastName"
              value="<%= formData.lastName || '' %>"
              autocomplete="family-name"
              class="input input-bordered w-full" />
          </div>

          <div class="form-control mb-3">
            <label class="label" for="email">
              <span class="label-text font-medium">Email</span>
            </label>
            <input type="text" id="email" name="email"
              value="<%= formData.email || '' %>"
              autocomplete="email"
              class="input input-bordered w-full" />
          </div>

          <div class="form-control mb-6">
            <label class="label" for="password">
              <span class="label-text font-medium">Password</span>
            </label>
            <input type="password" id="password" name="password"
              autocomplete="new-password"
              class="input input-bordered w-full" />
            <p class="text-xs text-gray-400 mt-1">8 to 12 characters, must include uppercase, lowercase, number, and symbol.</p>
          </div>

          <button type="submit" class="btn btn-success w-full">Create Account</button>
        </form>

        <p class="text-center text-sm text-gray-500 mt-4">
          Already registered? <a href="/log-in" class="link link-success">Log In</a>
        </p>

      </div>
    </div>

  </div>
</div>
