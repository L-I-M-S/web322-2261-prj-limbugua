<div class="card bg-white border border-gray-100 shadow-md hover:shadow-lg transition-all">
  <figure class="h-48 overflow-hidden">
    <img src="<%= kit.imageUrl %>" alt="<%= kit.title %>"
      class="w-full h-full object-cover"
      onerror="this.src='https://placehold.co/400x200/16a34a/ffffff?text=MamaMia'" />
  </figure>
  <div class="card-body p-4">
    <h2 class="card-title text-green-900 text-base"><%= kit.title %></h2>
    <p class="text-xs text-gray-500 italic"><%= kit.includes %></p>
    <p class="text-sm text-gray-600 mt-1"><%= kit.description %></p>
    <div class="flex justify-between text-xs text-gray-400 border-t mt-2 pt-2">
      <span><%= kit.cookingTime %> min</span>
      <span><%= kit.servings %> servings</span>
    </div>
    <div class="flex justify-between items-center mt-3">
      <span class="text-lg font-bold text-green-700">$<%= kit.price.toFixed(2) %></span>
      <% if (sessionUser && sessionUser.role === 'customer') { %>
        <a href="/cart" class="btn btn-sm btn-success">Go to Cart</a>
      <% } else if (sessionUser && sessionUser.role === 'clerk') { %>
        <a href="/mealkits/list" class="btn btn-sm btn-outline btn-success">Manage</a>
      <% } else { %>
        <a href="/sign-up" class="btn btn-sm btn-warning">Order Now</a>
      <% } %>
    </div>
  </div>
</div>
